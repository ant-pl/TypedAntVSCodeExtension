{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "TypedAnt",
    "scopeName": "source.ant",
    
    "settings": {
        "foreground": "#D4D4D4",
        "background": "#1E1E1E"
    },
    
    "tokenColors": [
        {
            "name": "Primitive Types",
            "scope": "storage.type.primitive.TypedAnt",
            "settings": {
                "foreground": "#7884C0"
            }
        },
        {
            "name": "Functions",
            "scope": "entity.name.function.TypedAnt",
            "settings": {
                "foreground": "#DCDC90"
            }
        },
        {
            "name": "Keywords",
            "scope": "keyword.control.TypedAnt",
            "settings": {
                "foreground": "#CF8049"
            }
        }
    ],
    
    "patterns": [
        {"include": "#purple"},
        {"include": "#keywords"},
        {"include": "#strings"},
        {"include": "#comments"},
        {"include": "#numeric-literals"},
        {"include": "#boolean-literals"},
        {"include": "#variables"},
        {"include": "#function-names"}
    ],
    
    "repository": {
        "purple": {
            "name": "storage.type.primitive.TypedAnt",
            "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|usize|isize)\\b"
        },
        "function-names": {
            "name": "entity.name.function.TypedAnt",
            "match": "\\b([a-zA-Z_\\u4e00-\\u9fa5][a-zA-Z0-9_\\u4e00-\\u9fa5]*)\\s*(?=\\()"
        },
        "variables": {
            "patterns": [{
                "name": "variable.other.TypedAnt",
                "match": "\\b([a-zA-Z_\\u4e00-\\u9fa5][a-zA-Z0-9_\\u4e00-\\u9fa5]*)\\b(?![^\\s]*\\()"
            }]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.TypedAnt",
                "match": "(?i)\\b(if|else|while|extern|impl|const|return|struct|func|let|self|new)\\b"
            }]
        },
        "strings": {
            "name": "string.quoted.double.TypedAnt",
            "begin": "\"",
            "end": "\"",
            "patterns": [{
                "name": "constant.character.escape.TypedAnt",
                "match": "\\\\."
            }]
        },
        "comments": {
            "name": "comment.line.double-slash",
            "begin": "//",
            "end": "\n",
            "patterns": [{
                "name": "constant.character.escape.TypedAnt",
                "match": "\\\\."
            }]
        },
        "numeric-literals": {
            "name": "constant.numeric.TypedAnt",
            "match": "\\b[0-9]+(?:\\.[0-9]*)?(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64)?\\b"
        },
        "boolean-literals": {
            "name": "constant.language.boolean.TypedAnt",
            "match": "(?i)\\b(?:true|false)\\b"
        }
    }
}